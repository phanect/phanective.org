:host
  display: block

* {
  margin: 0
  padding: 0
}

div.project-wrapper
  max-width: 250px

  padding: 0.5rem
  border: 2px
  border-style: solid
  border-color: #c0c0c0
  border-radius: 7px

h1
  display: inline
  font-size: 1.2rem
  margin-right: 0.5rem

p.term
  display: inline
  font-weight: 900
  font-size: 1.125rem

p.description
  margin-top: 0.4rem
  font-size: 1rem
